---
import Layout from '../layouts/Layout.astro';
import { featuredDishes } from '../data/menu.js';
---
<Layout title="Home" activePage="home">

  <section class="hero">
    <div class="hero-slides">
      <div class="hero-slide" style="background-image: url('/hero1.jpg')"></div>
      <div class="hero-slide" style="background-image: url('/hero2.jpg')"></div>
      <div class="hero-slide" style="background-image: url('/hero3.jpg')"></div>
    </div>
    <div class="hero-overlay"></div>

    <div class="hero-content">
      <img src="/signboard.png" alt="Dhaka Thai & Grill" class="hero-signboard" />
      <!-- <p class="hero-slogan">Authentic Flavours. Taste You Trust.</p>
      <div class="hero-cuisines">
        <span>Bangladeshi</span><span>Chinese</span><span>Thai</span><span>Kabab &amp; Grill</span>
      </div>
      -->
      <div class="hero-btns">
        <a href="/menu"  class="btn-primary">Explore Menu</a>
        <a href="/order" class="btn-green">Order Online</a>
        <a href="/contact" class="btn-outline">Contact Us</a>
      </div>
    </div>

    <div class="hero-dots">
      <button class="hero-dot active" data-slide="0"></button>
      <button class="hero-dot" data-slide="1"></button>
      <button class="hero-dot" data-slide="2"></button>
    </div>
  </section>

  <section class="about-strip">
    <div>
      <div class="about-label">Our Story</div>
      <h2 class="about-heading">About <span class="about-heading-brand">Dhaka Thai &amp; Grill</span></h2>
      <p class="about-body">
        At Dhaka Thai &amp; Grill, we bring together the bold flavours of Thai and Chinese cuisine, 
        our signature grill favourites, and authentic Bangladeshi dishes—all in one place for you to enjoy.
        <br/><br/>
        Every meal is prepared fresh using quality ingredients, with care taken to ensure great taste and consistency in every order. 
        Whether you’re picking up a quick bite or planning a family meal, we aim to make your experience simple, satisfying, and reliable.
        <br/><br/>
        Our goal is to be your trusted takeout spot—where you can always count on flavourful food, efficient service, and a menu that offers something for everyone.
        <br/><br/>
        With a skilled and experienced culinary team in Toronto, we’re dedicated to serving food that feels both authentic and comforting, every time you visit.
      </p>
      <div class="about-stats">
        <div><div class="stat-num">50+</div><div class="stat-label">Menu Items</div></div>
        <div><div class="stat-num">4</div><div class="stat-label">Cuisines</div></div>
        <!-- <div><div class="stat-num">100%</div><div class="stat-label">Halal</div></div> -->
        <div class="halal-stat">
          <img src="/halal-logo.png" alt="Halal Certified" class="halal-logo" />
        </div>
      </div>
      <div style="margin-top:2rem">
        <a href="/about" class="btn-outline">Our Full Story</a>
      </div>
    </div>
    <div class="about-img-stack">
      <div class="about-img-main">
        <img src="/about-food.jpg" alt="Fresh food at Dhaka Thai & Grill" class="about-food-img" />
      </div>

    </div>
  </section>

  <div class="ornament-divider">✦ ✦ ✦</div>

  <div class="section-header">
    <div class="section-label">Chef's Selection</div>
    <h2 class="section-title">Signature <em>Dishes</em></h2>
  </div>

  <div class="featured-grid">
    {featuredDishes.map((dish) => (
      <div class="featured-card">
        <div class="card-cat">{dish.category}</div>
        <div class="card-name">{dish.name}</div>
        <div class="card-desc">{dish.desc}</div>
        <div class="card-price">{dish.price}</div>
        <div class="card-corner"></div>
      </div>
    ))}
  </div>

  <div class="mid-banner">
  <div class="mid-banner-content">
    <p>Come dine with us or place your order over the phone. We also offer catering for parties, family gatherings, and corporate events.</p>

    <div class="mid-banner-info">
      <div class="mid-banner-info-item">
        <span class="info-icon">📍</span>
        <span>50 Danforth Road, Scarborough, ON M1L 3W4</span>
      </div>
      <div class="mid-banner-info-item">
        <span class="info-icon">📞</span>
        <a href="tel:14166377137">(416) 637-7137</a>
      </div>
      <div class="mid-banner-info-item">
        <span class="info-icon whatsapp-icon">
          <svg viewBox="0 0 24 24" fill="currentColor" width="16" height="16" style="vertical-align:middle">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/>
            <path d="M12 0C5.373 0 0 5.373 0 12c0 2.127.558 4.122 1.531 5.855L.057 23.882l6.199-1.448A11.945 11.945 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.818a9.806 9.806 0 01-5.031-1.384l-.36-.214-3.733.872.936-3.63-.235-.373A9.818 9.818 0 012.182 12C2.182 6.57 6.57 2.182 12 2.182S21.818 6.57 21.818 12 17.43 21.818 12 21.818z"/>
          </svg>
        </span>
        <a href="tel:14378692007">(437) 869-2007</a>
      </div>
    </div>

    <div class="mid-banner-social">
      <a href="https://instagram.com/dhakathaiandgrill" target="_blank" rel="noopener" class="social-link">
        <svg viewBox="0 0 24 24" fill="currentColor" width="18" height="18">
          <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/>
        </svg>
        @dhakathaiandgrill
      </a>
      <a href="https://facebook.com/dhakathaiandgrill" target="_blank" rel="noopener" class="social-link">
        <svg viewBox="0 0 24 24" fill="currentColor" width="18" height="18">
          <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
        </svg>
        @dhakathaiandgrill
      </a>
    </div>

    <div style="margin-top:2rem; display:flex; gap:1rem; justify-content:center; flex-wrap:wrap;">
      <a href="/order" class="btn-primary">Order Online</a>
      <a href="/contact" class="btn-green">Get Directions</a>
    </div>
  </div>
</div>

</Layout>

<script>
  const slides = document.querySelectorAll('.hero-slide');
  const dots   = document.querySelectorAll('.hero-dot');
  let current = 0;
  let timer: ReturnType<typeof setInterval>;

  function goTo(n: number) {
    slides[current].classList.remove('active');
    dots[current].classList.remove('active');
    current = (n + slides.length) % slides.length;
    slides[current].classList.add('active');
    dots[current].classList.add('active');
  }

  function startTimer() {
    timer = setInterval(() => goTo(current + 1), 5000);
  }

  dots.forEach((dot, i) => {
    dot.addEventListener('click', () => { clearInterval(timer); goTo(i); startTimer(); });
  });

  if (slides.length) { slides[0].classList.add('active'); startTimer(); }
</script>

<style>
  .hero {
    position: relative; height: calc(100vh - 72px); min-height: 600px;
    display: flex; align-items: center; justify-content: center;
    text-align: center; overflow: hidden;
  }
  .hero-slides { position: absolute; inset: 0; }
  .hero-slide {
    position: absolute; inset: 0;
    background-size: cover; background-position: center;
    opacity: 0; transition: opacity 1.2s ease;
    background-color: var(--dark-card2);
    background-image: linear-gradient(135deg, #1A1008 0%, #2A1A0A 50%, #1A1008 100%);
  }
  .hero-slide.active { opacity: 1; }
  .hero-overlay {
    position: absolute; inset: 0; z-index: 1;
    background: linear-gradient(
      to bottom,
      rgba(14,8,6,0.55) 0%,
      rgba(14,8,6,0.35) 40%,
      rgba(14,8,6,0.65) 100%
    );
  }
  .hero-content {
    position: relative; z-index: 2;
    max-width: 820px; padding: 2rem;
    display: flex; flex-direction: column; align-items: center; gap: 1rem;
  }
  .hero-signboard {
    width: min(600px, 90vw);
    height: auto;
    animation: fadeUp 0.8s ease both;
  }
  .hero-cuisines {
    display: flex; gap: 0.6rem; justify-content: center; flex-wrap: wrap;
    animation: fadeUp 0.8s 0.25s ease both;
  }
  .hero-cuisines span {
    font-size: 0.58rem; letter-spacing: 0.2em; text-transform: uppercase; font-weight: 600;
    padding: 0.25rem 0.8rem; border: 1px solid rgba(201,162,39,0.4); color: var(--cream-dim);
  }
  .hero-btns {
    display: flex; gap: 0.8rem; justify-content: center; flex-wrap: wrap;
    animation: fadeUp 0.8s 0.35s ease both;
    margin-top: 0.5rem;
  }
  .hero-dots {
    position: absolute; bottom: 5rem; left: 50%; transform: translateX(-50%);
    display: flex; gap: 0.6rem; z-index: 3;
  }
  .hero-dot {
    width: 8px; height: 8px; border-radius: 50%;
    background: rgba(245,236,215,0.35); border: none; cursor: pointer;
    transition: background 0.3s, transform 0.3s;
  }
  .hero-dot.active { background: var(--gold); transform: scale(1.3); }
  .hero-scroll {
    position: absolute; bottom: 1.5rem; left: 50%; transform: translateX(-50%);
    display: flex; flex-direction: column; align-items: center; gap: 0.5rem;
    color: var(--text-muted); font-size: 0.6rem; letter-spacing: 0.2em; text-transform: uppercase;
    z-index: 3; animation: fadeUp 0.8s 0.5s ease both;
  }
  .hero-scroll-line {
    width: 1px; height: 40px; background: linear-gradient(to bottom, var(--gold), transparent);
    animation: scrollPulse 2s infinite;
  }

  .signboard-section {
    background: var(--cream);
    padding: 3rem 2rem;
    display: flex; justify-content: center;
  }
  .signboard-wrap {
    max-width: 900px; width: 100%;
    border: 2px solid rgba(226,35,26,0.2);
    overflow: hidden;
  }
  .signboard-img {
    width: 100%; display: block;
    mix-blend-mode: multiply;
  }

  .about-strip {
    padding: 6rem 2rem; display: grid; grid-template-columns: 1fr 1fr;
    gap: 5rem; max-width: 1100px; margin: 0 auto; align-items: center;
  }
  .about-label {
    font-size: 0.65rem; letter-spacing: 0.3em; text-transform: uppercase;
    color: var(--gold); margin-bottom: 1rem; display: flex; align-items: center; gap: 0.8rem;
  }
  .about-label::before { content: ''; width: 30px; height: 1px; background: var(--gold); }
  .about-heading {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(1.8rem, 4vw, 2.8rem); font-weight: 600; line-height: 1.1;
    color: var(--cream); margin-bottom: 1.5rem;
  }
  .about-heading-brand {
    font-family: 'Lora', serif;
    font-weight: 700;
    font-style: normal;
    color: var(--red);
    white-space: nowrap;
  }
  .about-body { font-size: 0.85rem; line-height: 1.9; color: var(--cream-dim); font-weight: 300; }
  .about-stats {
    display: flex; gap: 2.5rem; margin-top: 2.5rem;
    padding-top: 2rem; border-top: 1px solid var(--border);
    position: relative;
  }
  .stat-num { font-family: 'Cormorant Garamond', serif; font-size: 2.5rem; font-weight: 700; color: var(--gold); line-height: 1; }
  .stat-label { font-size: 0.6rem; letter-spacing: 0.15em; text-transform: uppercase; color: var(--text-muted); margin-top: 0.2rem; }
  .halal-stat {
  display: flex; align-items: center;
  position: absolute; right: 5%; top: 95%; transform: translateY(-50%);
}

  .halal-logo {
    height: 105px; width: auto;
  }
  .about-img-stack { position: relative; }
  .about-img-main {
    width: 100%; aspect-ratio: 4/5;
    background: var(--dark-card2); border: 1px solid var(--border);
    display: flex; align-items: center; justify-content: center; overflow: hidden; position: relative;
  }
  .about-food-img {
  width: 100%; height: 100%; object-fit: cover;
  position: absolute; inset: 0; z-index: 2; display: block;
  } 
  
  .featured-grid {
    display: grid; grid-template-columns: repeat(3, 1fr);
    gap: 1.5px; max-width: 1200px; margin: 0 auto; padding: 0 2rem 6rem;
  }
  .featured-card {
    background: var(--dark-card); border: 1px solid var(--border);
    padding: 2.5rem 2rem; position: relative; overflow: hidden; transition: border-color 0.3s;
  }
  .featured-card::before {
    content: ''; position: absolute; top: 0; left: 0; right: 0; height: 3px;
    background: linear-gradient(90deg, transparent, var(--red), transparent);
    transform: scaleX(0); transition: transform 0.4s;
  }
  .featured-card:hover { border-color: rgba(201,162,39,0.4); }
  .featured-card:hover::before { transform: scaleX(1); }
  .card-cat { font-size: 0.58rem; letter-spacing: 0.25em; text-transform: uppercase; color: var(--gold); margin-bottom: 1rem; }
  .card-name { font-family: 'Cormorant Garamond', serif; font-size: 1.5rem; font-weight: 600; color: var(--cream); margin-bottom: 0.5rem; line-height: 1.2; }
  .card-desc { font-size: 0.78rem; color: var(--text-muted); line-height: 1.7; font-weight: 300; }
  .card-price { font-family: 'Cormorant Garamond', serif; font-size: 1.6rem; font-weight: 700; color: var(--gold); margin-top: 1.5rem; }
  .card-corner { position: absolute; bottom: 1.5rem; right: 1.5rem; width: 40px; height: 40px; opacity: 0.08; border-right: 2px solid var(--gold); border-bottom: 2px solid var(--gold); }

  .mid-banner {
  position: relative; padding: 6rem 2rem 5rem; text-align: center; overflow: hidden;
  background: linear-gradient(160deg, #0A0504 0%, #160A06 50%, #0A0504 100%);
  border-top: 3px solid var(--red);
}
.mid-banner::before {
  content: ''; position: absolute; inset: 0;
  background:
    radial-gradient(ellipse 60% 60% at 20% 50%, rgba(226,35,26,0.08) 0%, transparent 70%),
    radial-gradient(ellipse 60% 60% at 80% 50%, rgba(15,106,68,0.08) 0%, transparent 70%);
}
.mid-banner-content { position: relative; z-index: 1; max-width: 650px; margin: 0 auto; }
.mid-banner h2 {
  font-family: 'Cormorant Garamond', serif;
  font-size: clamp(1.8rem, 5vw, 3rem); font-weight: 700;
  color: var(--gold-light); margin-bottom: 1rem; line-height: 1.1;
}
.mid-banner p {
  font-size: 1.05rem; color: rgba(245,236,215,0.85);
  font-weight: 300; line-height: 1.9; margin-bottom: 2.5rem;
  letter-spacing: 0.3px;
}
.mid-banner-info {
  display: flex; flex-direction: column; gap: 0.7rem;
  margin-bottom: 1.8rem; align-items: center;
}
.mid-banner-info-item {
  display: flex; align-items: center; gap: 0.6rem;
  font-size: 0.88rem; color: var(--cream-dim);
}
.mid-banner-info-item a { color: var(--cream-dim); text-decoration: none; transition: color 0.2s; }
.mid-banner-info-item a:hover { color: var(--gold); }
.info-icon { font-size: 1rem; flex-shrink: 0; }
.whatsapp-icon { color: #25D366; }
.mid-banner-social {
  display: flex; gap: 1.5rem; justify-content: center;
  margin-bottom: 2rem; flex-wrap: wrap;
}
.social-link {
  display: flex; align-items: center; gap: 0.5rem;
  font-size: 0.72rem; font-weight: 600; letter-spacing: 0.08em;
  color: var(--cream-dim); text-decoration: none;
  transition: color 0.2s;
}
.social-link:hover { color: var(--gold); }
.social-link:first-child svg { color: #E1306C; }
.social-link:last-child svg { color: #1877F2; }
  @media (max-width: 768px) {
    .about-strip { grid-template-columns: 1fr; gap: 3rem; }
    .about-img-stack { margin-top: 1rem; }
    .about-img-main { aspect-ratio: 16/9; }
    .about-stats { flex-wrap: wrap; gap: 1.5rem; }
    .featured-grid { grid-template-columns: 1fr; }
  }
</style>
