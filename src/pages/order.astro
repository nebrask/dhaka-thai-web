---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Order Online" activePage="order">

  <div class="order-hero">
    <div class="order-hero-content">
      <div class="section-label">Quick &amp; Easy</div>
      <h1>Order <em>Online</em></h1>
      <p>Order in just a few clicks and enjoy fresh, flavourful meals—prepared right on time.</p>
    </div>
  </div>

  <section class="order-body">

    <div class="order-phone-banner">
      <div class="order-contact-row">
        <div class="order-contact-item">
          <div class="order-contact-label">📞 Call Us</div>
          <a href="tel:14166377137" class="order-contact-num">(416) 637-7137</a>
        </div>
        <div class="order-contact-divider"></div>
        <div class="order-contact-item">
          <div class="order-contact-label" style="color:#25D366">
            <svg viewBox="0 0 24 24" fill="currentColor" width="13" height="13" style="vertical-align:middle;margin-right:3px">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/>
              <path d="M12 0C5.373 0 0 5.373 0 12c0 2.127.558 4.122 1.531 5.855L.057 23.882l6.199-1.448A11.945 11.945 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.818a9.806 9.806 0 01-5.031-1.384l-.36-.214-3.733.872.936-3.63-.235-.373A9.818 9.818 0 012.182 12C2.182 6.57 6.57 2.182 12 2.182S21.818 6.57 21.818 12 17.43 21.818 12 21.818z"/>
            </svg>
            WhatsApp
          </div>
          <a href="https://wa.me/14378692007" target="_blank" class="order-contact-num">(437) 869-2007</a>
        </div>
      </div>
    </div>

    <div class="section-header" style="padding-top:4rem">
      <div class="section-label">Order Through</div>
      <h2 class="section-title">Delivery <em>Platforms</em></h2>
      <p style="font-size:0.82rem;color:var(--text-muted);margin-top:1rem;font-weight:300">
        Find us on your favourite delivery app — links will be added here once active.
      </p>
    </div>

    <div class="platform-grid">
      <div class="platform-card">
        <div class="platform-logo uber">Uber Eats</div>
        <div class="platform-name">Uber Eats</div>
        <div class="platform-desc">Search "Dhaka Thai &amp; Grill" on the Uber Eats app or website.</div>
        <div class="platform-badge coming">Link Coming Soon</div>
      </div>
      <div class="platform-card">
        <div class="platform-logo skip">SkipTheDishes</div>
        <div class="platform-name">SkipTheDishes</div>
        <div class="platform-desc">Find us on SkipTheDishes for fast delivery in Scarborough.</div>
        <div class="platform-badge coming">Link Coming Soon</div>
      </div>
      <div class="platform-card">
        <div class="platform-logo door">DoorDash</div>
        <div class="platform-name">DoorDash</div>
        <div class="platform-desc">Order through DoorDash for convenient delivery to your door.</div>
        <div class="platform-badge coming">Link Coming Soon</div>
      </div>
    </div>

    <div class="order-hours-box">
      <div class="order-hours-title">📅 Our Hours</div>
      <div class="order-hours-grid">
        <div><span>Monday – Friday</span><span>11:00 AM – 10:00 PM</span></div>
        <div><span>Saturday</span><span>9:00 AM – 10:00 PM</span></div>
        <div><span>Sunday</span><span>9:00 AM – 10:00 PM</span></div>
        <div class="weekend-note"><span>★ Weekend Breakfast</span><span>9:00 AM – 1:00 PM</span></div>
      </div>
    </div>

    <div class="order-catering-box">
      <h3>Planning an Event?</h3>
      <p>We offer catering for parties, family gatherings, and corporate events. Call us to discuss your requirements.</p>
      <a href="/contact" class="btn-primary" style="margin-top:1.5rem">Contact for Catering</a>
    </div>

  </section>

</Layout>

<style>
  .order-hero {
    height: 38vh; min-height: 260px; position: relative;
    display: flex; align-items: center; justify-content: center; text-align: center;
    background: linear-gradient(160deg, var(--dark) 0%, var(--dark-card2) 100%); overflow: hidden;
  }
  .order-hero::before {
    content: ''; position: absolute; inset: 0;
    background: radial-gradient(ellipse 70% 60% at 50% 50%, rgba(15,106,68,0.35) 0%, transparent 70%);
  }
  .order-hero-content { position: relative; z-index: 1; }
  .order-hero-content h1 { font-family: 'Cormorant Garamond', serif; font-size: clamp(2.2rem, 6vw, 4.5rem); font-weight: 700; color: var(--cream); margin: 0.3rem 0; }
  .order-hero-content h1 em { color: var(--green); font-style: normal; }
  .order-hero-content p { font-size: 0.8rem; color: var(--text-muted); letter-spacing: 0.05em; margin-top: 0.5rem; }

  .order-body { max-width: 900px; margin: 0 auto; padding: 3rem 2rem 6rem; }

  .order-phone-banner {
    border: 1px solid var(--border);
    border-left: 4px solid var(--red);
    background: rgba(255,255,255,0.03);
    padding: 2rem 2.5rem;
    margin: 2rem auto 0;
    max-width: 600px;
  }
  .order-contact-row {
    display: flex; align-items: center; justify-content: center;
    gap: 2rem; flex-wrap: wrap;
    max-width: 500px; margin: 0 auto;
  }
  .order-contact-item { text-align: center; }
  .order-contact-label {
    font-size: 0.6rem; letter-spacing: 0.2em; text-transform: uppercase;
    color: var(--text-muted); margin-bottom: 0.4rem;
  }
  .order-contact-num {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.6rem; font-weight: 700;
    color: var(--cream); text-decoration: none;
    text-shadow: 0 2px 12px rgba(226,35,26,0.4);
    transition: color 0.2s; display: block;
  }
  .order-contact-num:hover { color: var(--gold); }
  .order-contact-divider { width: 1px; height: 50px; background: var(--border); }

  .platform-grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 1.5rem; margin-bottom: 4rem; }
  .platform-card { background: var(--dark-card); border: 1px solid var(--border); padding: 2rem; text-align: center; transition: border-color 0.3s; }
  .platform-card:hover { border-color: rgba(201,162,39,0.4); }
  .platform-logo { font-size: 0.75rem; font-weight: 700; letter-spacing: 0.05em; padding: 0.6rem 1rem; margin-bottom: 1rem; display: inline-block; border-radius: 4px; }
  .uber  { background: #000; color: #fff; }
  .skip  { background: #F96302; color: #fff; }
  .door  { background: #FF3008; color: #fff; }
  .platform-name { font-family: 'Cormorant Garamond', serif; font-size: 1.2rem; font-weight: 600; color: var(--cream); margin-bottom: 0.5rem; }
  .platform-desc { font-size: 0.73rem; color: var(--text-muted); line-height: 1.6; margin-bottom: 1rem; }
  .platform-badge { font-size: 0.62rem; letter-spacing: 0.15em; text-transform: uppercase; font-weight: 700; padding: 0.3rem 0.8rem; display: inline-block; }
  .coming { background: rgba(201,162,39,0.15); color: var(--gold); border: 1px solid rgba(201,162,39,0.3); }

  .order-hours-box { background: var(--dark-card); border: 1px solid var(--border); padding: 2rem; margin-bottom: 2rem; }
  .order-hours-title { font-family: 'Cormorant Garamond', serif; font-size: 1.3rem; font-weight: 600; color: var(--cream); margin-bottom: 1.2rem; }
  .order-hours-grid { display: flex; flex-direction: column; gap: 0.5rem; }
  .order-hours-grid div { display: flex; justify-content: space-between; font-size: 0.82rem; color: var(--cream-dim); padding: 0.4rem 0; border-bottom: 1px solid rgba(201,162,39,0.08); }
  .order-hours-grid div:last-child { border-bottom: none; }
  .order-hours-grid div span:last-child { color: var(--gold); font-family: 'Cormorant Garamond', serif; font-size: 0.9rem; }
  .weekend-note span:first-child { color: var(--gold-light); }

  .order-catering-box {
    background: linear-gradient(135deg, var(--green-dark), var(--dark-card2));
    border: 1px solid var(--green); padding: 2.5rem; text-align: center;
  }
  .order-catering-box h3 { font-family: 'Cormorant Garamond', serif; font-size: 1.6rem; font-weight: 600; color: var(--cream); margin-bottom: 0.8rem; }
  .order-catering-box p { font-size: 0.82rem; color: var(--cream-dim); font-weight: 300; line-height: 1.8; }

  @media (max-width: 640px) {
    .platform-grid { grid-template-columns: 1fr; }
    .order-phone-banner { padding: 1.5rem; }
    .order-contact-row { flex-direction: column; gap: 1.2rem; }
    .order-contact-divider { width: 60px; height: 1px; }
  }
</style>