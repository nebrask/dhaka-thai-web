---
const { activePage } = Astro.props;
---
<nav>
  <div class="nav-logo-wrap">
    <a href="/"><img src="/logo.png" alt="Dhaka Thai & Grill" class="nav-logo-img" /></a>
  </div>

  <div class="nav-links-wrap">
    <ul class="nav-links">
      <li><a href="/"       data-active={activePage === 'home'}>Home</a></li>
      <li><a href="/menu"   data-active={activePage === 'menu'}>Menu</a></li>
      <li><a href="/about"  data-active={activePage === 'about'}>About</a></li>
      <li><a href="/order"  data-active={activePage === 'order'}>Order Online</a></li>
      <li><a href="/contact" data-active={activePage === 'contact'}>Contact</a></li>
    </ul>
  </div>

  <div class="nav-cta-wrap">
    <a href="/order" class="nav-cta">Order Now</a>
  </div>

  <button class="hamburger" id="hamburgerBtn" aria-label="Toggle menu">
    <span></span><span></span><span></span>
  </button>
</nav>

<div class="mobile-menu" id="mobileMenu">
  <a href="/">Home</a>
  <a href="/menu">Menu</a>
  <a href="/about">About</a>
  <a href="/order">Order Online</a>
  <a href="/contact">Contact</a>
  <a href="/order" style="color:var(--gold);font-weight:700">→ Order Now</a>
</div>

<script>
  document.getElementById('hamburgerBtn')?.addEventListener('click', () => {
    document.getElementById('mobileMenu')?.classList.toggle('open');
  });
  document.querySelectorAll('.mobile-menu a').forEach(a => {
    a.addEventListener('click', () => document.getElementById('mobileMenu')?.classList.remove('open'));
  });
</script>
